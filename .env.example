# Koru MVP — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA commits .env — está gitignored.
#
# REGLA CRÍTICA: las variables con prefijo VITE_ se incrustan en el bundle
# del cliente y son visibles para cualquier usuario. SOLO usar VITE_ para
# vars públicas (URLs de proxies, flags). NUNCA para API keys secretas.
# Las API keys secretas van en vars server-side (sin VITE_) y se leen
# desde el middleware de Vite (vite.config.ts) o el backend Express.

# ============================================================
# NVIDIA (proveedor predeterminado) — server-side only
# ============================================================
# API key de https://build.nvidia.com/ — sin prefijo VITE_ para no exponerla.
NVIDIA_API_KEY=
# URL base del API. Default: https://integrate.api.nvidia.com
NVIDIA_BASE_URL=https://integrate.api.nvidia.com
# Modelo default. Nemotron-3-Ultra-550b es el más capaz.
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# ============================================================
# OpenRouter (fallback) — server-side only
# ============================================================
# API keys de https://openrouter.ai/ — soporta múltiples separadas por coma.
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_API_KEYS=
# Modelos fallback (se rotan si el principal cae). Defaults razonables.
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,openai/gpt-oss-120b:free,google/gemma-4-31b-it:free

# ============================================================
# Google Gemini (generación de imágenes free tier) — server-side only
# ============================================================
GOOGLE_API_KEY=

# ============================================================
# MiniMax (provider alternativo) — server-side only
# ============================================================
# OAuth token de MiniMax. Se obtiene via scripts/minimax-oauth.ts.
MINIMAX_ACCESS_TOKEN=

# ============================================================
# Ollama (local, opcional) — para embeddings y modelos locales
# ============================================================
# URL de Ollama local. El proxy de Vite mapea /ollama → 127.0.0.1:11434.
VITE_OPEN_MODEL_BASE_URL=/ollama/v1
VITE_OPEN_MODEL_API_KEY=ollama
VITE_OPEN_MODEL_MODEL=llama3.1
# Setear a "1" para habilitar Ollama como provider local.
VITE_OPEN_MODEL_ENABLED=

# ============================================================
# DEPRECATED — FreeLLMAPI (no usar en producción)
# ============================================================
# ⚠️ Estas vars tienen prefijo VITE_ y se EXPOSE al bundle del cliente.
# Se mantienen por compatibilidad con el motor client-side legacy (que
# está marcado como muerto en la auditoría B1). Fase 2.14 decidirá si
# se eliminan definitivamente.
# Si las seteás, verás un warning en consola: "VITE_FREELLMAPI_API_KEY
# expone la key al bundle. Usar proxy server-side en producción."
VITE_FREELLMAPI_BASE_URL=http://127.0.0.1:3001
VITE_FREELLMAPI_API_KEY=
VITE_FREELLMAPI_MODEL=auto

# ============================================================
# BlueSminds (provider opcional, no default)
# ============================================================
BLUESMINDS_API_KEY=
BLUESMINDS_FALLBACK_API_KEYS=
BLUESMINDS_MODEL=mimo-v2.5
